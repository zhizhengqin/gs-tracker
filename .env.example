# ===== LLM 配置（AI 分析，两种方式二选一）=====
# 方式一：Kimi（与 Claude Code 同款 Anthropic 兼容接口，推荐）
# 本地开发：shell 已导出 ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN 时无需填写
# Docker 部署：把下面两行的值从你本机 shell 环境复制过来
ANTHROPIC_BASE_URL=https://api.kimi.com/coding
ANTHROPIC_AUTH_TOKEN=sk-kimi-...
# 模型名（可选）：默认依次读取 GS_LLM_MODEL → ANTHROPIC_MODEL → kimi-for-coding
GS_LLM_MODEL=kimi-for-coding

# 方式二：官方 Anthropic API（填写后上面三行可留空/删除）
# ANTHROPIC_API_KEY=sk-ant-...
# GS_LLM_MODEL=claude-sonnet-4-20250514

# Database
DATABASE_URL=sqlite:///data/db/gs_tracker.db

# Output
REPORT_OUTPUT_DIR=output/reports

# Public base URL for report links in notifications
PUBLIC_BASE_URL=https://your-domain.com

# Notification retry settings
NOTIFIER_MAX_ATTEMPTS=3
NOTIFIER_BACKOFF_BASE=1.0

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
FEISHU_WEBHOOK=
DINGTALK_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Extra data sources (optional)
SEC_API_KEY=
FINRA_API_KEY=
CBOE_API_KEY=
BLOOMBERG_API_KEY=

# SEC EDGAR User-Agent (required, include contact email)
SEC_USER_AGENT="GS-Tracker your-email@example.com"

# Signal scoring weights JSON (optional)
SIGNAL_SCORING_WEIGHTS={"holding_change":0.35,"research_view":0.25,"block_trade":0.15,"options_flow":0.10,"etf_flow":0.10,"macro_view":0.05}
